{
  "name": "@northskysocial/migration-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:test": "react-router dev --mode test",
    "start": "react-router-serve ./build/server/index.js",
    "test:env": "tsx bin/testenv.ts",
    "test:jest": "jest --maxWorkers=1",
    "test:backend": "docker pull ghcr.io/northskysocial/pds-migration:main && docker run -it northskysocial/pds-migration:main",
    "test:backend-arm64": "cargo run --bin pdsmigration-web --manifest-path pds-migration/Cargo.toml",
    "test": "npx concurrently -i --kill-others npm:test:env npm:dev:test npm:test:backend",
    "test:arm64": "npx concurrently -i --kill-others npm:test:env npm:dev:test npm:test:backend-arm64",
    "typecheck": "wrangler types && react-router typegen && tsc"
  },
  "dependencies": {
    "@1password/save-button": "^1.3.0",
    "@atproto/api": "^0.18.7",
    "@chakra-ui/react": "^3.30.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/museomoderno": "^5.2.9",
    "@NorthskySocial/northwoods-ui": "^0.1.0",
    "@react-router/cloudflare": "^7.10.1",
    "@react-router/node": "^7.10.1",
    "@react-router/serve": "^7.10.1",
    "@scure/bip39": "^2.0.1",
    "@types/debug": "^4.1.12",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-rsc": "^0.5.3",
    "better-sqlite3": "^12.5.0",
    "check-password-strength": "^3.0.0",
    "debug": "^4.4.3",
    "ioredis": "^5.8.2",
    "isbot": "^5",
    "next-themes": "^0.4.6",
    "niceware": "^4.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-icons": "^5.5.0",
    "react-router": "^7.10.1",
    "react-server-dom-parcel": "^19.2.3",
    "react-server-dom-webpack": "^19.2.3",
    "use-debounce": "^10.0.6",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@atproto/dev-env": "^0.3.196",
    "@cloudflare/vite-plugin": "^1.17.1",
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "^7.10.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "commander": "^14.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "inquirer": "^13.0.2",
    "jest": "^30.2.0",
    "jest-puppeteer": "^11.0.0",
    "nodemailer": "^7.0.11",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.49.0",
    "vite": "^7.2.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.52.1"
  }
