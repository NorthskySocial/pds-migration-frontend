{
  "name": "@northskysocial/migration-fe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:test": "react-router dev --mode test",
    "start": "react-router-serve ./build/server/index.js",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx}\"",
    "format:check": "prettier --check \"**/*.{js,ts,jsx,tsx}\"",
    "test:env": "tsx bin/testenv.ts",
    "test:jest": "jest --maxWorkers=1",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.unit.config.js",
    "test:unit:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.unit.config.js --watch",
    "test:backend": "docker pull ghcr.io/northskysocial/pds-migration:main && docker run -it northskysocial/pds-migration:main",
    "test:backend-arm64": "cargo run --bin pdsmigration-web --manifest-path pds-migration/Cargo.toml",
    "test": "npx concurrently -i --kill-others npm:test:env npm:dev:test npm:test:backend",
    "test:arm64": "npx concurrently -i --kill-others npm:test:env npm:dev:test npm:test:backend-arm64",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@1password/save-button": "^1.3.0",
    "@atproto/api": "^0.19.9",
    "@chakra-ui/react": "^3.34.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/museomoderno": "^5.2.9",
    "@NorthskySocial/northwoods-ui": "^0.1.0",
    "@react-router/node": "^7.14.1",
    "@react-router/serve": "^7.14.1",
    "@scure/bip39": "^2.0.1",
    "@types/debug": "^4.1.13",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-rsc": "^0.5.24",
    "better-sqlite3": "^12.9.0",
    "check-password-strength": "^3.0.0",
    "debug": "^4.4.3",
    "ioredis": "^5.8.2",
    "isbot": "^5",
    "next-themes": "^0.4.6",
    "niceware": "^4.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.5.0",
    "react-router": "^7.14.1",
    "react-server-dom-parcel": "^19.2.5",
    "react-server-dom-webpack": "^19.2.5",
    "use-debounce": "^10.0.6",
    "use-local-storage-state": "^19.5.0"
  },
  "devDependencies": {
    "@atproto/dev-env": "^0.4.4",
    "@eslint/js": "^9.39.1",
    "@react-router/dev": "^7.14.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "commander": "^14.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.5.0",
    "inquirer": "^13.4.1",
    "jest": "^30.3.0",
    "jest-puppeteer": "^11.0.0",
    "nodemailer": "^7.0.11",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
